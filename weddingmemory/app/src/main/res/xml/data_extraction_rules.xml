<?xml version="1.0" encoding="utf-8"?>
<!--
    data_extraction_rules.xml — Cloud Backup rules (Android 12+).
    Sensitive data (tokens, cached albums) is excluded from cloud backups.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database" path="." />
    </device-transfer>
</data-extraction-rules>
