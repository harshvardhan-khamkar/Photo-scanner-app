<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security configuration.
    - Debug builds: allow cleartext (HTTP) to any domain for local testing
    - Release builds: HTTPS only (cleartext blocked)
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow HTTP only in debug builds for local backend -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
