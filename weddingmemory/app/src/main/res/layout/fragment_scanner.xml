<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Full-screen live camera preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:implementationMode="performance"
        app:scaleType="fillCenter"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <!-- Back button — top-left corner -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="40dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/bg_circle_semi_transparent"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:contentDescription="Go back"
        android:scaleType="centerInside"
        android:padding="12dp"
        xmlns:tools="http://schemas.android.com/tools"
        tools:ignore="HardcodedText" />

    <!-- "RECOGNIZING..." overlay — shown during processing -->
    <FrameLayout
        android:id="@+id/recognizingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <ProgressBar
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:indeterminate="true"
                android:indeterminateTint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Recognizing..."
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                tools:ignore="HardcodedText"
                xmlns:tools="http://schemas.android.com/tools" />

        </LinearLayout>

    </FrameLayout>

    <!-- Permission-denied overlay -->
    <LinearLayout
        android:id="@+id/permissionDeniedLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Camera permission is required to scan wedding albums."
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@android:color/white"
            tools:ignore="HardcodedText"
            xmlns:tools="http://schemas.android.com/tools" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Open Settings"
            tools:ignore="HardcodedText"
            xmlns:tools="http://schemas.android.com/tools" />

    </LinearLayout>

</FrameLayout>
