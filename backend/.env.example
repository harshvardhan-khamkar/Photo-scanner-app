# ── App Settings ─────────────────────────────────────────
APP_NAME="Wedding Memory Platform"
DEBUG=False

# ── MongoDB ──────────────────────────────────────────────
MONGODB_URI="mongodb://localhost:27017"
DATABASE_NAME="wedding_platform"

# ── Security ─────────────────────────────────────────────
# IMPORTANT: Generate real keys before deploying!
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="CHANGE-ME"
ADMIN_API_KEY="CHANGE-ME"

# ── CORS ─────────────────────────────────────────────────
# Comma-separated origins, or * for all (dev only)
ALLOWED_ORIGINS="https://yourdomain.com"

# ── Storage ──────────────────────────────────────────────
STORAGE_BACKEND="local"

# ── AWS (uncomment when switching to S3) ─────────────────
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="us-east-1"
# S3_BUCKET_NAME="wedding-memories-storage"
# CLOUDFRONT_DOMAIN="https://cdn.example.com"